[resource]
script = ExtResource("1")
id = &"healing_herb"
display_name = "Heilkraut"
description = "Mildes Kraut, das Wunden schneller schließen kann."
plant_type = 0
growing_seasons = 7
allowed_biome_ids = PackedStringArray("meadow")
