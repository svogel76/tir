[resource]
script = ExtResource("1")
id = &"dark_forest"
display_name = "Dunkelwald"
description = "Dichter Wald mit hohem Nebel und staerkerer Anderswelt-Praesenz."
vegetation = Array[Resource]([SubResource("PlantPop_oak"), SubResource("PlantPop_yew"), SubResource("PlantPop_toxic_mushroom")])
